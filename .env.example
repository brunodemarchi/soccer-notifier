# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user/chat ID (send any message to your bot, then check:
# https://api.telegram.org/bot<TOKEN>/getUpdates)
# Comma-separated for multiple users
TELEGRAM_CHAT_IDS=111111111,222222222

# RapidAPI key (api-football-v1.p.rapidapi.com)
RAPIDAPI_KEY=your_rapidapi_key_here

# Optional overrides
# DB_PATH=/data/soccer.db
# LOG_PATH=/data/logs
